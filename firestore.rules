rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is an administrator
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/administradores/$(request.auth.uid));
    }

    // Helper function to check if the document belongs to the authenticated user
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 1. Products (productos) - Anyone can read, only admin can write, clients can decrement stock on checkout
    match /productos/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
                    && request.resource.data.stock is int
                    && request.resource.data.stock >= 0
                    && request.resource.data.stock < resource.data.stock;
    }

    // 2. Categories (categorias) - Anyone can read, only admin can write
    match /categorias/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Delivery Slots (horariosDisponibles) - Anyone can read, only admin can write
    match /horariosDisponibles/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Configs (configuracion) - Anyone can read, only admin can write
    match /configuracion/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Customers (clientes) - User can read/write their own profile, admin can read/write all
    match /clientes/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    // 6. Admins (administradores) - Only admins can read/write
    match /administradores/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow write: if isAdmin();
    }

    // 7. Orders (pedidos) - Users can create, read their own, admins can read/write all
    match /pedidos/{orderId} {
      allow create: if request.auth != null
                    && request.resource.data.customerId == request.auth.uid
                    && request.resource.data.keys().hasAll([
                      'id', 'date', 'createdAt', 'total', 'status',
                      'paymentStatus', 'paymentMethod', 'items',
                      'shipping', 'customerId', 'voucherUrl'
                    ])
                    && (request.resource.data.total is float || request.resource.data.total is int)
                    && request.resource.data.total > 0
                    && (request.resource.data.createdAt is int || request.resource.data.createdAt is float)
                    && request.resource.data.status == "En preparación"
                    && request.resource.data.paymentStatus == "pending"
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.paymentMethod in ["Tarjeta", "Yape", "Transferencia"]
                    && (
                      request.resource.data.paymentMethod == "Tarjeta"
                      || (
                        request.resource.data.voucherUrl is string
                        && request.resource.data.voucherUrl.size() > 0
                      )
                    );
      allow read: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
